{
  "name": "product-assistant-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "mobile",
    "backend"
  ],
  "scripts": {
    "start:server": "npm run start --workspace=backend",
    "dev:server": "concurrently \"npm run dev --workspace=backend\" \"npm run search-service --workspace=backend\"",
    "dev": "npm run dev:server",
    "dev:web": "npm run dev --workspace=web",
    "start:mobile": "npm run start --workspace=mobile",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sails-mongo": "1.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "metro": "^0.80.12",
    "metro-config": "^0.80.12",
    "metro-core": "^0.80.12",
    "metro-resolver": "^0.80.12",
    "prettier": "^3.2.4"
  },
  "overrides": {
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-screens": "~4.16.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native": "0.81.5",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
