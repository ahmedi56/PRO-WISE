{
  "name": "product-assistant-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "mobile",
    "backend"
  ],
  "scripts": {
    "start:server": "npm run start --workspace=backend",
    "dev:server": "npm run dev --workspace=backend",
    "dev": "npm run dev:server",
    "dev:web": "npm run dev --workspace=web",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "start:mobile": "npm run start --workspace=mobile",
    "lint": "npx --yes cross-env ESLINT_USE_FLAT_CONFIG=false eslint ."
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.2.4"
  }
}
