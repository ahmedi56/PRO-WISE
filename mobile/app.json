{
  "expo": {
    "name": "PRO-WISE",
    "slug": "product-assistant-mobile",
    "version": "1.0.0",
    "icon": "./assets/pro-wise.png",
    "splash": {
      "image": "./assets/pro-wise.png",
      "resizeMode": "contain",
      "backgroundColor": "#161B22"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/pro-wise.png",
        "backgroundColor": "#161B22"
      },
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/pro-wise.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}