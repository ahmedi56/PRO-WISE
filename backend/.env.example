# SECURITY CONFIGURATION
# ----------------------
# Change this to a long, random string in production
JWT_SECRET=dev_secret_key_change_in_production_123!

# Initial password for seeded administrators (superadmin, admin, technician)
# Change this before the first lift to secure your initial accounts
INITIAL_ADMIN_PASSWORD=Admin123!

# DATABASE CONFIGURATION
# ----------------------
# Local MongoDB (used in development)
MONGODB_URL=mongodb://127.0.0.1:27017/prowise

# APPLICATION CONFIGURATION
# -------------------------
FRONTEND_URL=http://localhost:5173
PORT=1337
NODE_ENV=development
